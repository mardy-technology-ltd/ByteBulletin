// ByteBulletin — Prisma Schema
// Clean Architecture Data Layer
// 8 Entities: User, Account, Category, Source, Article, AISummary, Bookmark, UserPreference, RssFetchLog

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AISentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum FetchStatus {
  SUCCESS
  FAILED
  PARTIAL
}

enum DigestFrequency {
  DAILY
  WEEKLY
}

enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
}

// ─────────────────────────────────────────────
// AUTH ENTITIES (Auth.js v5 compatible)
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null for OAuth users
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  bookmarks     Bookmark[]
  preferences   UserPreference?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// DOMAIN ENTITIES
// ─────────────────────────────────────────────

model Category {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?
  color        String   @default("#6366f1") // Indigo default
  icon         String?  // Lucide icon name
  articleCount Int      @default(0)         // Denormalized counter
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  sources  Source[]
  articles Article[]

  @@map("categories")
}

model Source {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  feedUrl       String    @unique
  siteUrl       String
  logoUrl       String?
  categoryId    String
  isActive      Boolean   @default(true)
  fetchInterval Int       @default(30) // Minutes
  lastFetchedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  category  Category      @relation(fields: [categoryId], references: [id])
  articles  Article[]
  fetchLogs RssFetchLog[]

  @@map("sources")
}

model Article {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  excerpt     String        @db.Text
  content     String?       @db.Text // Full body if available from RSS
  originalUrl String        @unique
  imageUrl    String?
  author      String?
  publishedAt DateTime
  sourceId    String
  categoryId  String
  status      ArticleStatus @default(PUBLISHED)
  viewCount   Int           @default(0)
  isFeatured  Boolean       @default(false)
  tags        String[]      // PostgreSQL text array
  readingTime Int           @default(1) // Estimated minutes
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  source    Source      @relation(fields: [sourceId], references: [id])
  category  Category    @relation(fields: [categoryId], references: [id])
  aiSummary AISummary?
  bookmarks Bookmark[]

  // Indexes for common query patterns
  @@index([publishedAt(sort: Desc), status])
  @@index([categoryId, publishedAt(sort: Desc)])
  @@index([sourceId, publishedAt(sort: Desc)])
  @@index([slug])
  @@index([isFeatured, publishedAt(sort: Desc)])
  @@map("articles")
}

model AISummary {
  id          String      @id @default(cuid())
  articleId   String      @unique
  summary     String      @db.Text
  keyPoints   String[]    // Bullet points array
  sentiment   AISentiment @default(NEUTRAL)
  model       String      @default("gemini-1.5-flash")
  tokensUsed  Int         @default(0)
  generatedAt DateTime    @default(now())

  // Relations
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("ai_summaries")
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId]) // Prevent duplicate bookmarks
  @@index([userId, createdAt(sort: Desc)])
  @@map("bookmarks")
}

model UserPreference {
  id                 String          @id @default(cuid())
  userId             String          @unique
  followedCategories String[]        // Category IDs
  emailDigest        Boolean         @default(false)
  digestFrequency    DigestFrequency @default(WEEKLY)
  theme              ThemePreference @default(SYSTEM)
  updatedAt          DateTime        @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model RssFetchLog {
  id              String      @id @default(cuid())
  sourceId        String
  status          FetchStatus
  articlesFound   Int         @default(0)
  articlesCreated Int         @default(0)
  error           String?     @db.Text
  duration        Int         @default(0) // Milliseconds
  fetchedAt       DateTime    @default(now())

  // Relations
  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, fetchedAt(sort: Desc)])
  @@map("rss_fetch_logs")
}
