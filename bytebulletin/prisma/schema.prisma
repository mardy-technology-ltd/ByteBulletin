// ByteBulletin — Prisma Schema
// Clean Architecture Data Layer
// Supports Auth, Domain Entities, Tags, SEO, Analytics, Media, Newsletter, and Global Settings

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AISentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum FetchStatus {
  SUCCESS
  FAILED
  PARTIAL
}

enum DigestFrequency {
  DAILY
  WEEKLY
}

enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
}

enum NewsletterStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  FAILED
}

enum EventType {
  PAGEVIEW
  CLICK
  AI_SUMMARY_EXPAND
  SHARE
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum ReactionType {
  LIKE
  LOVE
  LAUGH
  THINKING
  FIRE
}

// ─────────────────────────────────────────────
// AUTH ENTITIES (Auth.js v5 compatible)
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null for OAuth users
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  bookmarks     Bookmark[]
  reactions     ArticleReaction[]
  comments      Comment[]
  preferences   UserPreference?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// DOMAIN ENTITIES
// ─────────────────────────────────────────────

model Category {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?
  color        String   @default("#6366f1") // Indigo default
  icon         String?  // Lucide icon name
  articleCount Int      @default(0)         // Denormalized counter
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  sources  Source[]
  articles Article[]

  @@map("categories")
}

model Source {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  feedUrl       String    @unique
  siteUrl       String
  logoUrl       String?
  categoryId    String
  isActive      Boolean   @default(true)
  fetchInterval Int       @default(30) // Minutes
  lastFetchedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  category  Category      @relation(fields: [categoryId], references: [id])
  articles  Article[]
  fetchLogs RssFetchLog[]

  @@map("sources")
}

model Tag {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  createdAt   DateTime  @default(now())
  
  // Relations
  articles    Article[] // Implicit many-to-many

  @@map("tags")
}

model Article {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  excerpt     String        @db.Text
  content     String?       @db.Text // Full body if available from RSS
  originalUrl String        @unique
  imageUrl    String?
  author      String?
  publishedAt DateTime
  sourceId    String
  categoryId  String
  status      ArticleStatus @default(PUBLISHED)
  viewCount   Int           @default(0)
  isFeatured  Boolean       @default(false)
  readingTime Int           @default(1) // Estimated minutes
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  source      Source      @relation(fields: [sourceId], references: [id])
  category    Category    @relation(fields: [categoryId], references: [id])
  tags        Tag[]       // Implicit many-to-many
  aiSummary   AISummary?
  seo         SeoMetadata?
  bookmarks   Bookmark[]
  reactions   ArticleReaction[]
  comments    Comment[]
  media       MediaAsset[]
  analytics   AnalyticsEvent[]

  // Indexes for common query patterns
  @@index([publishedAt(sort: Desc), status])
  @@index([categoryId, publishedAt(sort: Desc)])
  @@index([sourceId, publishedAt(sort: Desc)])
  @@index([slug])
  @@index([isFeatured, publishedAt(sort: Desc)])
  @@map("articles")
}

model AISummary {
  id          String      @id @default(cuid())
  articleId   String      @unique
  summary     String      @db.Text
  keyPoints   String[]    // Bullet points array
  sentiment   AISentiment @default(NEUTRAL)
  model       String      @default("gemini-1.5-flash")
  tokensUsed  Int         @default(0)
  generatedAt DateTime    @default(now())

  // Relations
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("ai_summaries")
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId]) // Prevent duplicate bookmarks
  @@index([userId, createdAt(sort: Desc)])
  @@map("bookmarks")
}

model ArticleReaction {
  id        String       @id @default(cuid())
  userId    String
  articleId String
  type      ReactionType @default(LIKE)
  createdAt DateTime     @default(now())

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([articleId])
  @@map("article_reactions")
}

model Comment {
  id        String   @id @default(cuid())
  articleId String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, createdAt(sort: Desc)])
  @@map("comments")
}

model UserPreference {
  id                 String          @id @default(cuid())
  userId             String          @unique
  followedCategories String[]        // Category IDs
  emailDigest        Boolean         @default(false)
  digestFrequency    DigestFrequency @default(WEEKLY)
  theme              ThemePreference @default(SYSTEM)
  updatedAt          DateTime        @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model RssFetchLog {
  id              String      @id @default(cuid())
  sourceId        String
  status          FetchStatus
  articlesFound   Int         @default(0)
  articlesCreated Int         @default(0)
  error           String?     @db.Text
  duration        Int         @default(0) // Milliseconds
  fetchedAt       DateTime    @default(now())

  // Relations
  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, fetchedAt(sort: Desc)])
  @@map("rss_fetch_logs")
}

// ─────────────────────────────────────────────
// ADVANCED ENTITIES
// ─────────────────────────────────────────────

model NewsletterSubscriber {
  id          String           @id @default(cuid())
  email       String           @unique
  status      NewsletterStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("newsletter_subscribers")
}

model NewsletterCampaign {
  id          String         @id @default(cuid())
  subject     String
  content     String         @db.Text
  status      CampaignStatus @default(DRAFT)
  sentAt      DateTime?
  sentCount   Int            @default(0)
  openCount   Int            @default(0)
  clickCount  Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("newsletter_campaigns")
}

model GlobalSetting {
  key         String   @id
  value       String   @db.Text // JSON stringified value
  description String?
  updatedAt   DateTime @updatedAt

  @@map("global_settings")
}

model SeoMetadata {
  id          String   @id @default(cuid())
  articleId   String   @unique
  title       String?  // Override for meta title
  description String?  @db.Text // Override for meta description
  ogImage     String?
  keywords    String[]
  canonical   String?
  updatedAt   DateTime @updatedAt

  // Relations
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("seo_metadata")
}

model AnalyticsEvent {
  id          String    @id @default(cuid())
  eventType   EventType
  path        String
  articleId   String?
  userId      String?   // Optional if authenticated
  ipHash      String?   // Anonymized IP hash
  userAgent   String?
  createdAt   DateTime  @default(now())

  // Relations
  article     Article?  @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt(sort: Desc)])
  @@index([articleId])
  @@map("analytics_events")
}

model MediaAsset {
  id          String    @id @default(cuid())
  url         String
  key         String    @unique // Storage key (e.g. S3 object key)
  type        MediaType @default(IMAGE)
  altText     String?
  width       Int?
  height      Int?
  size        Int?      // Bytes
  articleId   String?
  createdAt   DateTime  @default(now())

  // Relations
  article     Article?  @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@index([articleId])
  @@map("media_assets")
}
